# VocalMirror — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are optional — the app runs without any env config.

# ── Gradio Server ────────────────────────────────────────────
# Server hostname (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
VM_SERVER_NAME=0.0.0.0

# Port to listen on (default: 7860 — the HuggingFace Spaces default)
VM_PORT=7860

# Set to "true" to generate a public Gradio share link (useful for quick demos)
VM_SHARE=false

# ── Model cache ──────────────────────────────────────────────
# Override HuggingFace model cache directory (optional)
# HF_HOME=/path/to/cache
